<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>FirstJob.ai</title>

<style>
body { font-family: system-ui; margin:0; background:#f5f7fb; }
nav { padding:16px 24px; background:#fff; font-weight:800; border-bottom:1px solid #eee; }
.hero { padding:50px 20px; text-align:center; background:#2563eb; color:#fff; }
.container { max-width:720px; margin:30px auto; padding:20px; }
.card { background:#fff; padding:20px; border-radius:12px; border:1px solid #eee; }
input, textarea { width:100%; padding:10px; margin:8px 0 14px; border-radius:8px; border:1px solid #ddd; }
